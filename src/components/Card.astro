---
interface Props {
  variant?: 'sidebar' | 'work';
  label?: string;
  abbr?: string;
  title?: string;
}

const { variant = 'sidebar', label, abbr, title } = Astro.props;
---

{variant === 'work' ? (
  <div class="p-8 border border-border bg-bg transition duration-200 hover:border-ui/50 hover:-translate-y-0.5 rounded-sm">
    {abbr && <div class="font-alt text-[0.7rem] text-primary tracking-[0.08em] mb-5 opacity-80">{abbr}</div>}
    {title && <h3 class="text-[1.15rem] font-bold mb-3 text-text tracking-[-0.01em]">{title}</h3>}
    <div class="text-prose-sm text-muted leading-[1.75] m-0"><slot /></div>
  </div>
) : (
  <div class="p-5 border border-border bg-ui/3 rounded-sm">
    {label && <p class="font-alt text-[0.5rem] text-primary tracking-widest uppercase mb-3">{label}</p>}
    <slot />
  </div>
)}
